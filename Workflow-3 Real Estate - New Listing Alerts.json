    {
      "parameters": {
        "jsCode": "const leads = $input.all().map(item => item.json);\nconst property = $('Map Property Data').item.json;\n\nreturn leads.map(lead => ({\n  json: {\n    Lead_Name: lead.fields['Name'],\n    Contact: lead.fields['Contact'],\n    Property_Name: property.Property_Name || property['Property Name'] || '',\n    Area: property.Area || '',\n    Price: property.Price || '',\n    Bedrooms: property.Bedrooms || '',\n    Description: (property.Description || '').replace(/\\n/g, ' ').replace(/\\r/g, ' ')\n  }\n}));"
      },
