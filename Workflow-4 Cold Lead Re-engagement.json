      "parameters": {
        "jsCode": "const content = $input.first().json.choices[0].message.content;\nconst clean = content.replace(/```json|```/g, \"\").trim();\nconst parsed = JSON.parse(clean);\n\nreturn [{\n  json: {\n    subject: parsed.subject,\n    body: parsed.body,\n    Lead_Name: $('Search records').first().json.fields['Name'],\n    Contact: $('Search records').first().json.fields['Contact'],\n    Record_ID: $('Search records').first().json.id\n  }\n}];"
