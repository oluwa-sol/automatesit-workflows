              "value": "={{ [{\"role\": \"system\", \"content\": \"You are a real estate assistant. Return ONLY valid JSON, nothing else.\"}, {\"role\": \"user\", \"content\": \"Write a warm personalised re-engagement email for a cold real estate lead.\\n\\nLead Name: \" + $json['Lead Name'] + \"\\nProperty Interest: \" + $json['Property Interest'] + \"\\nBudget: \" + $json['Budget'] + \"\\n\\nReturn exactly:\\n{\\\"subject\\\": \\\"email subject line\\\",\\n\\\"body\\\": \\\"warm personalised email body\\\"}\\n\\nKeep it short, friendly, and not salesy. Mention their specific property interest. Return ONLY JSON, nothing else.\"}] }}"
