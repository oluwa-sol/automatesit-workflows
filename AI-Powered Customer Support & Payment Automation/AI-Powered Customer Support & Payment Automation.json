    {
      "parameters": {
        "sendTo": "={{ $json.body.data.customer.email }}",
        "subject": "=New payment received\n\nCustomer: {{ $json.body.data.customer.email }}\nAmount: {{ $json.body.data.amount / 100 }}\nReference: {{ $json.body.data.reference }}\nStatus: {{ $json.body.data.status }}",
        "message": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <title>Payment Confirmation – AutomateIt</title>\n</head>\n<body style=\"margin:0;padding:0;background:#f4f4f8;font-family:Arial,sans-serif;\">\n  <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f4f4f8;padding:40px 16px;\">\n    <tr>\n      <td align=\"center\">\n        <table width=\"560\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#ffffff;border-radius:6px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.08);\">\n\n          <!-- Accent bar -->\n          <tr>\n            <td height=\"4\" style=\"background:linear-gradient(90deg,#00c97a,#00b8ff,#7c3aed);font-size:0;\">&nbsp;</td>\n          </tr>\n\n          <!-- Header -->\n          <tr>\n            <td align=\"center\" style=\"padding:40px 48px 32px;border-bottom:1px solid #f0f0f6;\">\n              <p style=\"font-size:16px;font-weight:800;color:#1a1a2e;margin:0 0 24px;\">● AutomateIt</p>\n              <span style=\"display:inline-block;background:#f0fdf8;border:1px solid #bbf7e0;border-radius:100px;padding:6px 16px;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:#00a863;\">● Payment Confirmed</span>\n              <h1 style=\"font-size:26px;font-weight:800;color:#1a1a2e;margin:20px 0 8px;\">Payment Successful</h1>\n              <p style=\"font-size:12px;color:#9090b0;margin:0;\">Hi {{ $json.body.data.customer.email }}, your payment has been received.</p>\n            </td>\n          </tr>\n\n          <!-- Amount block -->\n          <tr>\n            <td style=\"padding:32px 48px 0;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f8f8fc;border:1px solid #ebebf5;border-left:4px solid #00c97a;border-radius:4px;\">\n                <tr>\n                  <td style=\"padding:20px 24px;\">\n                    <p style=\"font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#9090b0;margin:0 0 8px;\">Total Charged</p>\n                    <p style=\"font-size:32px;font-weight:800;color:#1a1a2e;margin:0;\">&#8358;&nbsp;{{ ($json.body.data.amount / 100).toLocaleString() }} <span style=\"font-size:13px;color:#00a863;font-weight:500;\">NGN</span></p>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Details table -->\n          <tr>\n            <td style=\"padding:24px 48px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"border:1px solid #ebebf5;border-radius:4px;border-collapse:collapse;\">\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td width=\"40%\" style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Email</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#3a3a5c;text-align:right;\">{{ $json.body.data.customer.email }}</td>\n                </tr>\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Amount</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#3a3a5c;text-align:right;\">&#8358;&nbsp;{{ ($json.body.data.amount / 100).toLocaleString() }}</td>\n                </tr>\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Payment Method</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#3a3a5c;text-align:right;\">{{ $json.body.data.channel }}</td>\n                </tr>\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Currency</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#3a3a5c;text-align:right;\">{{ $json.body.data.currency }}</td>\n                </tr>\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Date & Time</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#3a3a5c;text-align:right;\">{{ $json.body.data.paid_at }}</td>\n                </tr>\n\n                <tr style=\"border-bottom:1px solid #f4f4f8;\">\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Reference</td>\n                  <td style=\"padding:14px 20px;font-size:11px;color:#6060a0;text-align:right;font-family:'Courier New',monospace;\">{{ $json.body.data.reference }}</td>\n                </tr>\n\n                <tr>\n                  <td style=\"padding:14px 20px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:#9090b0;\">Status</td>\n                  <td style=\"padding:14px 20px;font-size:12px;color:#00a863;font-weight:600;text-align:right;\">{{ $json.body.data.status }}</td>\n                </tr>\n\n              </table>\n            </td>\n          </tr>\n\n          <!-- Message -->\n          <tr>\n            <td style=\"padding:0 48px 28px;\">\n              <p style=\"font-size:12px;line-height:1.9;color:#9090b0;margin:0;\">Keep this email as proof of payment. If you have any questions or need to make changes to your order, reach out to us directly and we will sort it out for you.</p>\n            </td>\n          </tr>\n\n          <!-- CTA -->\n          <tr>\n            <td style=\"padding:0 48px 36px;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background:#f8f8fc;border:1px solid #ebebf5;border-radius:4px;\">\n                <tr>\n                  <td style=\"padding:20px 24px;\">\n                    <p style=\"font-size:13px;font-weight:700;color:#3a3a5c;margin:0 0 4px;\">Need help or have questions?</p>\n                    <p style=\"font-size:12px;color:#9090b0;margin:0 0 16px;\">We typically respond within a few hours.</p>\n                    <a href=\"mailto:hello@automatesit.co\" style=\"display:inline-block;background:#1a1a2e;color:#ffffff;font-size:11px;font-weight:700;letter-spacing:1px;text-transform:uppercase;text-decoration:none;padding:10px 20px;border-radius:4px;\">Contact Us</a>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n          <!-- Footer -->\n          <tr>\n            <td style=\"padding:20px 48px;border-top:1px solid #f0f0f6;background:#fafafa;\">\n              <table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\">\n                <tr>\n                  <td style=\"font-size:11px;color:#c0c0d8;\">© 2026 AutomateIt</td>\n                  <td align=\"right\">\n                    <a href=\"#\" style=\"font-size:11px;color:#c0c0d8;text-decoration:none;margin-left:16px;\">automatesit.co</a>\n                    <a href=\"#\" style=\"font-size:11px;color:#c0c0d8;text-decoration:none;margin-left:16px;\">Privacy</a>\n                    <a href=\"#\" style=\"font-size:11px;color:#c0c0d8;text-decoration:none;margin-left:16px;\">Unsubscribe</a>\n                  </td>\n                </tr>\n              </table>\n            </td>\n          </tr>\n\n        </table>\n      </td>\n    </tr>\n  </table>\n</body>\n</html>",
