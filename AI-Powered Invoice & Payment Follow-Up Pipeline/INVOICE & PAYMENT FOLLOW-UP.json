    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  il.*\nFROM invoice_log il\nWHERE\n  il.status IN ('open', 'uncollectible')\n  AND il.days_overdue > 0\n  AND (\n    SELECT COUNT(*) FROM followup_log fl\n    WHERE fl.invoice_id = il.invoice_id\n    AND fl.sent_at > NOW() - INTERVAL '24 hours'\n  ) = 0\nORDER BY il.days_overdue DESC\nLIMIT 50;",
        "options": {}
      },
