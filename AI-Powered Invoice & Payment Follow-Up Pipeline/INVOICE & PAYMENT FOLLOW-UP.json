    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COUNT(*) FILTER (WHERE risk_score = 'high')   AS high_risk_count,\n  COUNT(*) FILTER (WHERE risk_score = 'medium') AS medium_risk_count,\n  COUNT(*) FILTER (WHERE risk_score = 'low')    AS low_risk_count,\n  COUNT(*)                                       AS total_overdue,\n  COALESCE(SUM(amount_due), 0)                  AS total_amount_outstanding,\n  CURRENT_DATE                                   AS report_date\nFROM invoice_log\nWHERE\n  status IN ('open', 'uncollectible')\n  AND days_overdue > 0;",
        "options": {}
      },
